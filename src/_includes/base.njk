<!DOCTYPE html>
<html lang="en">
  <head>
    {% set pageTitle = title or site.name %}
    {% set pageDescription = description or site.description %}
    {% set canonicalUrl = canonical or (site.url ~ page.url) %}
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="{{ pageDescription }}">
    <link rel="canonical" href="{{ canonicalUrl }}">
    <meta property="og:title" content="{{ pageTitle }}">
    <meta property="og:description" content="{{ pageDescription }}">
    <meta property="og:type" content="{{ 'article' if tags and 'blog' in tags else 'website' }}">
    <meta property="og:url" content="{{ canonicalUrl }}">
    <meta property="og:site_name" content="{{ site.name }}">
    <title>{{ pageTitle }}</title>
    {% set css %} {% include "style.css" %} {% endset %}
    <style>
      {{ css | cssmin | safe }}
    </style>
    <link rel="stylesheet" href="/css/mobile.css" media="(max-width: 650px)">
  </head>
  <body>
    {% include 'header.njk' %}
    <main>
    {% block content %} {# Render custom HTML content #}
      {{ content | safe }} {# Render markdown #}
    {% endblock %} 
    </main>
    <footer></footer>
    <script>
      document.querySelectorAll('main a[href]').forEach(a => {
        if (!a.closest('#blogs')) {
          a.target = '_blank';
          a.rel = 'noopener';
        }
      });
    </script>
  </body>
</html>
